-- HÀM KIỂM TRA KEY
local function checkTheKey()
    local enteredKey = string.gsub(InputFrame.Text, "%s+", "")
    if enteredKey == key then
        keyOk = true
        ScreenGui:Destroy()
        WindUI:Notify({Title = "Thành Công!", Content = "Đang tải Script...", Time = 2})
    else
        WindUI:Notify({Title = "Sai Key!", Content = "Vui lòng nhập lại.", Time = 2})
    end
end

